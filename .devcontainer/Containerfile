FROM node:22-slim
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*
RUN npm install -g pnpm opencode-ai

RUN mkdir -p /workspace && chown -R node:node /workspace

WORKDIR /workspace

ENV PAPERCLIP_HOME=/workspace/paperclip-data
ENV XDG_CONFIG_HOME=/workspace/.config
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

USER node

# Tạo thư mục data sau khi đã switch sang user node
RUN mkdir -p /workspace/paperclip-data