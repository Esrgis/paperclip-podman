ARG BASE=node:22-slim
FROM ${BASE}

# Cài đặt các công cụ hệ thống
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    jq \
    python3 \
    python3-pip \
    unzip \
    ca-certificates \
    dos2unix \
    && rm -rf /var/lib/apt/lists/*

# Cài đặt pnpm và opencode-ai
RUN npm install -g pnpm opencode-ai

# Cài đặt RTK
RUN curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh

# Chuẩn bị workspace
RUN mkdir -p /workspace && chown -R node:node /workspace

WORKDIR /workspace

ENV PAPERCLIP_HOME=/workspace/paperclip-data
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

USER node