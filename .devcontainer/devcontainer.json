{
    "name": "Paperclip-Pragmatic-Env",
    "build": {
        "dockerfile": "Containerfile",
        "args": {
            "BASE": "node:22-slim"
        }
    },
    "runArgs": [
        "--userns=keep-id"
    ],
    "workspaceFolder": "/workspace",
    "remoteUser": "node",
    "mounts": [
        "source=paperclip-data,target=/home/node/paperclip-data,type=volume"
    ],
    "containerEnv": {
        "PAPERCLIP_HOME": "/workspace/paperclip-data",
        "PATH": "/home/node/.npm-global/bin:/home/node/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    },
    "postCreateCommand": "dos2unix /workspace/.devcontainer/*.sh && bash /workspace/.devcontainer/setup.sh",
    "postStartCommand": "[ -d /workspace/paperclip-data ] && echo 'Paperclip ready' || echo 'Paperclip not ready yet'",
    "customizations": {
        "vscode": {
            "settings": {
                "telemetry.telemetryLevel": "off",
                "dev.containers.dockerPath": "podman",
                "dev.containers.dockerSocketPath": "unix:///run/user/1000/podman/podman.sock",
                "dev.containers.executeInWSL": true,
                "dev.containers.wsldistro": "Debian",
                "remote.WSL.initialAssumes": {
                    "useWSL": true,
                    "useWSLContainer": true,
                    "useWSLDevEnvironments": true
                }
            }
        }
    }
}