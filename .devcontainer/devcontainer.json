{
    "name": "Paperclip-Pragmatic-Env",
    "build": {
        "dockerfile": "Containerfile",
        "args": {
            "BASE": "node:22-slim"
        }
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder": "/workspace",
    "remoteUser": "node",
    "mounts": [
        "source=paperclip-data,target=/home/node/paperclip-data,type=volume"
    ],
    "containerEnv": {
        "PAPERCLIP_HOME": "/workspace/paperclip-data",
        "PATH": "/home/node/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    },
    "postCreateCommand": "bash /workspace/.devcontainer/setup.sh",
    "postStartCommand": "[ -d /workspace/paperclip ] && echo 'Paperclip ready' || echo 'Paperclip not ready yet'",
    "settings": {
        "telemetry.telemetryLevel": "off",
        "search.followSymlinks": false,
        "dev.containers.dockerPath": "podman"
    },
    "extensions": [
        "ms-vscode-remote.remote-containers"
    ]
}